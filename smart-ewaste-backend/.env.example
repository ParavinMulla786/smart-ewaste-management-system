# ===========================================
# ENVIRONMENT VARIABLES EXAMPLE
# ===========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/ewaste_db
MONGODB_DATABASE=ewaste_db

# MongoDB Authentication (if enabled)
# MONGODB_USERNAME=your_username
# MONGODB_PASSWORD=your_password

# JWT Configuration
# Generate a secure secret key: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_here_minimum_256_bits
JWT_EXPIRATION=86400000

# Email Configuration (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
APP_URL=http://localhost:3000

# AWS S3 Configuration
# Set AWS_ENABLED=true once you configure valid AWS credentials
AWS_ENABLED=false
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=smart-ewaste-bucket

# Server Configuration
SERVER_PORT=8080

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Logging Level
LOGGING_LEVEL=DEBUG
